# Katafract screenshot pipeline (Layer 2) — fastlane snapshot config
# Per-app: copy to <repo>/fastlane/Snapfile, customize devices + scheme.
# Run with `bundle exec fastlane screenshots` or `bundle exec fastlane submit_version_screenshots`.

# Devices: pick the device class(es) Apple requires for App Store Version submission.
# - iPhone 6.7": iPhone 16 Pro Max / iPhone 17 Pro Max  → ASC: APP_IPHONE_67 (1320×2868)
# - iPad Pro 13": iPad Pro 13-inch (M4 / M5)            → ASC: APP_IPD_PRX_3GEN_129 (2064×2752)
# Add iPhone 6.5", 5.5", iPad Pro 12.9" only if your minOsVersion supports the older device classes.

project("./Vaultyx.xcodeproj")

# Use UDIDs to bypass fastlane's simctl version resolution, which maps
# the "iOS 26.4" runtime name to OS=26.4 but xcodebuild requires OS=26.4.1.
# UDIDs are specific to chronos-macbuilder — update if runner is rebuilt.
devices([
  "B2D64AC7-7C8D-4D0E-9108-374CCD54B92A",  # iPhone 17 Pro Max (iOS 26.4.1)
  "63727949-16A4-46CB-8BD7-BCDEF8C8000A",  # iPad Pro 13-inch (M5) (iOS 26.4.1)
])

languages(["en-US"])

# UI test scheme name. Your XCUITest target lives here.
# Replace with your scheme.
scheme("VaultyxUITests")

output_directory("./fastlane/screenshots")
clear_previous_screenshots(true)
override_status_bar(true)       # Set status bar to 9:41 / Wifi / 100%
override_status_bar_arguments("--time 9:41 --batteryState charged --batteryLevel 100")

# Master launch args — keep ScreenshotMode flags here.
# For paywall capture, switch to --mock-unsubscribed.
# For subscribed-state UI, use --mock-subscribed.
launch_arguments([
  "--screenshots --skip-onboarding --mock-subscribed --mock-prices --force-dark-mode --seed-data sovereign-demo",
])

# Don't open HTML preview after capture (reduces noise).
skip_open_summary(true)

# Concurrent simulators — speeds up cold runs significantly.
concurrent_simulators(true)
