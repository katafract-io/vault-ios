# Katafract screenshot pipeline (Layer 2) — fastlane lanes
# Per-app: copy to <repo>/fastlane/Fastfile, no customization needed unless app
# has special build requirements.

require 'json'

default_platform(:ios)

before_all do
  dm = FastlaneCore::DeviceManager
  next unless dm.respond_to?(:simulators)
  next if dm.respond_to?(:_sims_pre_patch)
  orig = dm.method(:simulators)
  dm.define_singleton_method(:_sims_pre_patch, &orig)
  dm.define_singleton_method(:simulators) do |requested_os_type = ""|
    devs = dm._sims_pre_patch("")
    begin
      runtimes = JSON.parse(`xcrun simctl list runtimes --json 2>/dev/null`)["runtimes"]
      map = runtimes.each_with_object({}) do |rt, h|
        display = rt["name"].sub(/^iOS /, "")
        actual  = rt["version"]
        h[display] = actual if actual && display != actual
      end
      devs.each { |d| d.os_version = map[d.os_version] if d.os_type == "iOS" && map[d.os_version] }
    rescue => e
      UI.important("sim-version-patch: #{e.message}")
    end
    requested_os_type.empty? ? devs : devs.select { |d| d.os_type == requested_os_type }
  end
end

platform :ios do
  desc "Capture screenshots locally (output: fastlane/screenshots/)"
  lane :screenshots do
    capture_ios_screenshots
  end

  desc "Capture + upload App Store Version screenshots to ASC (no binary, no metadata)"
  lane :submit_version_screenshots do
    capture_ios_screenshots
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  desc "Re-upload screenshots from existing fastlane/screenshots/ without re-capturing"
  lane :resubmit_version_screenshots do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  desc "Capture IAP/subscription review screenshots (slim matrix: iPhone only, paywall frames)"
  lane :iap_review_refresh do
    # Note: Most of the upload+audit logic lives in the GitHub Actions workflow.
    # This lane captures locally for manual testing. The workflow automates
    # SSH to artemis + asc_screenshot_upload calls.
    capture_ios_screenshots
    UI.success("✓ Captured IAP screenshots to fastlane/screenshots/")
    UI.important("Workflow will upload to ASC via artemis when run in CI")
  end

  # Subscription + IAP review screenshots are uploaded via the shared CLI on
  # artemis: `python -m services.asc_screenshot_upload sub|iap ...`. fastlane
  # deliver does NOT handle those well. GitHub Actions workflow handles the
  # orchestration. See .github/workflows/iap-review-refresh.yml and
  # docs/IAP_REVIEW_SCREENSHOT_WORKFLOW.md for details.
end
