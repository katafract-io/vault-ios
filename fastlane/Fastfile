# Katafract screenshot pipeline (Layer 2) — fastlane lanes
# Per-app: copy to <repo>/fastlane/Fastfile, no customization needed unless app
# has special build requirements.

# simctl text output labels iOS 26.4.1 runtime as "-- iOS 26.4 --", so fastlane
# passes OS=26.4 to xcodebuild which requires the actual patch version (26.4.1).
# Remap device.os_version using simctl JSON before capture runs.
require 'json'
require 'fastlane_core/device_manager'
module FastlaneCore
  class DeviceManager
    class << self
      unless respond_to?(:_sims_pre_patch)
        alias_method :_sims_pre_patch, :simulators
        def simulators(requested_os_version: nil)
          devs = _sims_pre_patch(requested_os_version: nil)
          begin
            runtimes = JSON.parse(`xcrun simctl list runtimes --json 2>/dev/null`)["runtimes"]
            map = runtimes.each_with_object({}) do |rt, h|
              display = rt["name"].sub(/^iOS /, "")
              actual  = rt["version"]
              h[display] = actual if actual && display != actual
            end
            devs.each { |d| d.os_version = map[d.os_version] if d.os_type == "iOS" && map[d.os_version] }
          rescue => e
            UI.important("sim-version-patch failed: #{e.message}")
          end
          requested_os_version ? devs.select { |d| d.os_version == requested_os_version } : devs
        end
      end
    end
  end
end

default_platform(:ios)

platform :ios do
  desc "Capture screenshots locally (output: fastlane/screenshots/)"
  lane :screenshots do
    capture_ios_screenshots
  end

  desc "Capture + upload App Store Version screenshots to ASC (no binary, no metadata)"
  lane :submit_version_screenshots do
    capture_ios_screenshots
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  desc "Re-upload screenshots from existing fastlane/screenshots/ without re-capturing"
  lane :resubmit_version_screenshots do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  # Subscription + IAP review screenshots are uploaded via the shared CLI on
  # artemis: `python -m services.asc_screenshot_upload sub|iap ...`. fastlane
  # deliver does NOT handle those well. See SCREENSHOT_PIPELINE.md for the
  # commands.
end
