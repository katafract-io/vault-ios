# Katafract screenshot pipeline (Layer 2) — fastlane lanes
# Per-app: copy to <repo>/fastlane/Fastfile, no customization needed unless app
# has special build requirements.

default_platform(:ios)

platform :ios do
  desc "Capture screenshots locally (output: fastlane/screenshots/)"
  lane :screenshots do
    capture_ios_screenshots
  end

  desc "Capture + upload App Store Version screenshots to ASC (no binary, no metadata)"
  lane :submit_version_screenshots do
    capture_ios_screenshots
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  desc "Re-upload screenshots from existing fastlane/screenshots/ without re-capturing"
  lane :resubmit_version_screenshots do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  desc "Capture IAP review frames (capacity tier subscriptions only)"
  lane :iap_review_refresh do
    # Capacity tier tests only — frames 08-13, iPhone 16 Pro
    # Maps to SKUs: 100gb.monthly, 100gb.yearly, 1tb.monthly, 1tb.yearly, 5tb.monthly, 5tb.yearly
    # Upload handled by iap-review-refresh.yml workflow via artemis SSH

    test_methods = [
      "VaultyxScreenshotTests/testCaptureCapacity100gbMonthly",
      "VaultyxScreenshotTests/testCaptureCapacity100gbYearly",
      "VaultyxScreenshotTests/testCaptureCapacity1tbMonthly",
      "VaultyxScreenshotTests/testCaptureCapacity1tbYearly",
      "VaultyxScreenshotTests/testCaptureCapacity5tbMonthly",
      "VaultyxScreenshotTests/testCaptureCapacity5tbYearly",
    ]

    test_filter = test_methods.map { |m| "-only-testing=#{m}" }.join(" ")
    scheme = ENV["SCHEME"] || "Vaultyx"
    destination = ENV["SIMULATOR_DESTINATION"] || "generic/platform=iOS Simulator,name=iPhone 16 Pro"

    sh("xcodebuild test -project #{scheme}.xcodeproj -scheme #{scheme} -destination '#{destination}' -derivedDataPath /tmp/xcodebuild #{test_filter}")
  end

  # Subscription + IAP review screenshots are uploaded via the shared CLI on
  # artemis: `python -m services.asc_screenshot_upload sub|iap ...`. fastlane
  # deliver does NOT handle those well. See iap-review-refresh.yml for the
  # workflow implementation.
end
